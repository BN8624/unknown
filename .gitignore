# Godot 4 import/cache
.godot/

# 웹 내보내기 결과물 (아이폰 테스트용, 재생성 가능)
build/

# 상용 한글 폰트 (로컬/빌드 표시용, 공개 저장소엔 커밋하지 않음)
malgun.ttf
malgun.ttf.import

# 환경 변수·비밀 (절대 커밋 금지)
.env
.env.*

# 아트 마스터/중간본(대용량) — 게임은 사용 파일명만 로드
assets/ui/*_source.png
assets/ui/*_chroma_source.png
assets/ui/*_2x.png
assets/ui/*_preview.png
assets/ui/*_sheet.png

# 아트 납품 원본 폴더(대용량 마스터·소스) — 사용본만 assets/sd·ui에 복사
assets/art_order_test_delivery/
